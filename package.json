{
  "name": "agora-philosophy",
  "version": "0.1.0",
  "description": "A quiet, bilingual philosophy new-tab experience with ideas in context.",
  "private": true,
  "license": "GPL-3.0-or-later",
  "author": "NorthGateChat",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NorthGateChat/agora-philosophy.git"
  },
  "homepage": "https://github.com/NorthGateChat/agora-philosophy#readme",
  "bugs": {
    "url": "https://github.com/NorthGateChat/agora-philosophy/issues"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "build:extension": "vite build --config vite.extension.config.ts && node scripts/finalize-extension.mjs",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "package:extension": "npm run build:extension && node scripts/package-extension.mjs",
    "test": "npm run build && npm run build:extension && node --test tests/*.test.mjs",
    "test:extension": "npm run build:extension && node --test tests/extension-package.test.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next"
  },
  "dependencies": {
    "next": "16.2.10",
    "opencc-js": "1.4.1",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.45.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitejs/plugin-rsc": "0.5.28",
    "eslint": "10.7.0",
    "eslint-config-next": "16.2.10",
    "react-server-dom-webpack": "19.2.6",
    "sharp": "0.34.5",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.1.5",
    "wrangler": "4.112.0"
  },
  "overrides": {
    "postcss": "8.5.19"
  },
  "type": "module"
}
